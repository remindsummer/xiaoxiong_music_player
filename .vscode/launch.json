{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug (CodeLLDB)",
            "type": "lldb",
            "request": "launch",
            "args": [],
            "preLaunchTask": "CMake: Build",
            "terminal": "integrated",
            "stdio": "inherit",
            "linux": {
                "program": "${workspaceFolder}/build/xxMusic",
                "cwd": "${workspaceFolder}/build",
                "env": {
                    "PATH": "${env:HOME}/Qt/6.9.3/gcc_64/bin:${env:PATH}"
                }
            },
            "windows": {
                "program": "${workspaceFolder}/build/Debug/xxMusic.exe",
                "cwd": "${workspaceFolder}/build/Debug"
            }
        },
        {
            "name": "Debug (MSVC)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/Debug/xxMusic.exe",
            "args": [],
            "cwd": "${workspaceFolder}/build/Debug",
            "stopAtEntry": false,
            "preLaunchTask": "CMake: Build",
            "console": "integratedTerminal",
            "windows": {}
        }
    ]
}
